        let foundButtons = [];
        for (let i = 0; i <= 6; i++) {
            let btn = document.querySelector("img[name=level" + i + "]");
            if (btn) foundButtons.push('level' + i);
        }
        console.log('[Train] Available buttons:', foundButtons.length ? foundButtons.join(', ') : 'NONE FOUND');
        
        let clicked = false;
        for (let i of [3, 0, 1, 2, 4, 5, 6]) {
            try {
                let btn = document.querySelector("img[name=level" + i + "]");
                if (btn) { 
                    $(btn).trigger("mousedown"); 
                    console.log('[Train] Clicked level' + i + ' via jQuery mousedown'); 
                    clicked = true; 
                    break; 
                }
            } catch(e) {
                try {
                    let btn = document.querySelector("img[name=level" + i + "]");
                    if (btn) { btn.click(); console.log('[Train] Clicked level' + i + ' via native click'); clicked = true; break; }
