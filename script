const attentionState = {
    mode: 'normal',
    until: 0,
    multiplier: 1.0,

    update() {
        if (Date.now() < this.until) return;
        if (localStorage.hAttention === 'off') {
            this.mode = 'normal';
            this.multiplier = 1.0;
            this.until = Date.now() + 60000;
            return;
        }
        let focusPct = parseInt(localStorage.hFocusPct || 25, 10);
        let distractPct = parseInt(localStorage.hDistractPct || 30, 10);
        let roll = randomValue(1, 100);
        if (roll <= focusPct) {
            this.mode = 'focused';
            this.multiplier = randomValue(60, 85) / 100;
            this.until = Date.now() + randomValue(45000, 3 * 60000);
        } else if (roll <= (100 - distractPct)) {
            this.mode = 'normal';
            this.multiplier = randomValue(90, 115) / 100;
            this.until = Date.now() + randomValue(2 * 60000, 8 * 60000);
        } else {
            this.mode = 'distracted';
            this.multiplier = randomValue(130, 220) / 100;
            this.until = Date.now() + randomValue(30000, 4 * 60000);
        }
    },

    get() {
        this.update();
        return this.multiplier;
    }
};
