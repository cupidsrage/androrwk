function findJunk() {
    doAction(0, 'burn', '999999999', '', '', false);
    junkItems = [];

    let elm = document.getElementById(`general0`).elements[5];
    let currentCategory = '';
    let skipCategories = ['relics', 'others'];

    for (let n = 0; n < elm.length; n++) {
        let item = elm.options[n].value;
        let itemText = elm.options[n].innerText;

        // Category header
        if (item == '999999999') {
            currentCategory = itemText.replace(/_/g, '').trim().toLowerCase();
            continue;
        }

        // Skip equipped items
        if (itemText.indexOf('EQUIPPED') > -1 || itemText.indexOf('Equipped') > -1 || itemText.indexOf('equipped') > -1) continue;

        // Skip Relics and Others categories entirely
        if (skipCategories.indexOf(currentCategory) > -1) continue;

        // Store index + value so we can select by index
        junkItems.push({ index: n, value: item, name: itemText });
    }
    console.log('[Ash] findJunk: ' + junkItems.length + ' burnable items');
}

