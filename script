            }
			if (s_Chat.childNodes[n].innerHTML.indexOf("Melee`s Rage") > -1) {
						   localStorage.globalmasSec = "1";
                alert("Super Relic Found");
                writeSystemMessage("Please /wipe chat in order to continue.");
