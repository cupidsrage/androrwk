                doAction(0, 'train', 4, '', '', true);
                console.log('[Train] doAction train DUR sent');
                clicked = true;
            } catch(e) {
                console.log('[Train] doAction failed:', e.message);
            }
        }
        if (!clicked) {
            console.log('[Train] ALL METHODS FAILED - calling train()');
            train();
        }
        return;
    }
    if (manageLevel()) {
        return;
    }
    if (document.querySelector('#s_Response').innerText.indexOf("Enemy not found.") > -1) {
        doAction(0, 'battle', 0, '', '', true);
        return;
