        return;
    }

    if (task === "build" && goldSource === "da" && useRep && armyCheck === "forts") {
        delay = humanDelay(60, 130, 4);
        action = setTimeout(doAct, delay);
        return;
    }

    // ── Combat / everything else ───────────────────────────────────────────
    let baseLow  = parseInt(localStorage.hCombatMin || 50, 10);
    let baseHigh = parseInt(localStorage.hCombatMax || 120, 10);

    if (task === "ash" || task === "duel" || task === "acuman") {
        baseLow  = parseInt(localStorage.hCombatMin || 40, 10);
        baseHigh = parseInt(localStorage.hCombatMax || 100, 10);
    }

    if (task === "kingdom" || task === "build") {
        baseLow  = parseInt(localStorage.hBuildMin || 80, 10);
        baseHigh = parseInt(localStorage.hBuildMax || 180, 10);
    }

    delay = Math.floor(humanDelay(baseLow, baseHigh, 10) * fatigueMod());
    action = setTimeout(doAct, delay);
}

function doAct() {
    let craft   = document.querySelector("#auto-craft-check").checked;
    let enchant = document.querySelector("#auto-enchant-check").checked;
    let farm    = document.querySelector("#auto-farm-check").checked;

    if (!running || paused) return;

    const response = document.querySelector("#s_Response").innerText;

    // Cooldown message — just retry quickly, don't stop
    if (response === "You have not waited the necessary amount of time before doing another action. Now you must wait an additional 10 seconds.") {
        loop();
        return;
    }

    if (localStorage.globalmasSec === "1") { stop(); return; }
    if (task === "none")                    { stop(); return; }

    // ── TRAIN CHECK — intercept "You must train first" before any action ──
    if (response.indexOf("You must train first") > -1) {
        // Must wait for action bar to be full before we can train
        let bWidth = parseInt(document.querySelector("#BarneyEmpty").width, 10);
        let subDisp = document.getElementById("s_subbut0").style.display;
        if (bWidth < 100 || subDisp === 'none') {
            // Not ready — wait and retry
            action = setTimeout(doAct, 500);
            return;
        }
        console.log('[Train] doAct: action bar ready, training now');
        let clicked = false;
        for (let i of [3, 0, 1, 2, 4, 5, 6]) {
            try {
                let btn = document.querySelector("img[name=level" + i + "]");
                if (btn) { 
                    $(btn).trigger("mousedown"); 
                    console.log('[Train] doAct: triggered mousedown on level' + i); 
                    clicked = true; 
                    break; 
                }
            } catch(e) {}
        }
        if (!clicked) {
            console.log('[Train] doAct: no level buttons found');
            train();
        }
        // Wait for the game to process the train action
        action = setTimeout(doAct, randomValue(2000, 3000));
        return;
    }

    securityCheck();

    // ── INVENTORY FULL — force burn items before doing anything else ──
    if (response.indexOf("Inventory dangerously full") > -1 || response.indexOf("No more of that relic") > -1) {
        console.log('[Ash] doAct: inventory full — forcing burn');
        if (!globalSync) {
            burningItems = true;
        } else {
            localStorage.burnAsh = "true";
        }
        burnItems(true);
        loop();
        return;
    }

    // ── EQUIPPED ITEM — skip it and keep burning ──
    if (response.indexOf("EQUIPPED and cannot be sold") > -1 || response.indexOf("Equipped items cannot be sold") > -1) {
        console.log('[Ash] doAct: equipped item — skipping, ' + junkItems.length + ' items left');
        if (junkItems.length > 0) junkItems.shift();
        if (junkItems.length > 0) {
            burnItems(true);
        } else {
            burningItems = false;
            localStorage.burnAsh = "false";
        }
        loop();
        return;
    }

    // ── Dispatch task ─────────────────────────────────────────────────
    if (task === "ash") {
        if (craft)   craftCheck();
        if (enchant) enchantlvl();
        if (farm)    fightCheck();
    }
    if (task === "kingdom") kingdomBezz();
    if (task === "build")   kingdomBuilder();
    if (task === "rune" && isReady()) moveRunes();
    if (task === "profit")  profitfinder();
    if (task === "acuman")  autoduelLoop1();
    if (task === "duel")    autoduelLoop();

    loop();
}

function toggleRunState() {
    if (!paused) {
        if (running) {
            running = false;
            action = clearTimeout(doAct);
        } else {
            running = true;
            sessionStartTime = Date.now(); // reset fatigue timer on each new run
            loop();
        }
    } else {
        if (confirmStop == false) {
            confirmStop = true;
        } else {
            return;
        }
    }
}

function stop() {
    running = false;
    pause = false;
    action = clearTimeout(doAct);
}



