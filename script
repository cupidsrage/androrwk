var captchaSolving = false;
var lastCaptchaAttempt = null;
var lastCaptchaSolveTime = 0;

/* jshint esversion: 6 */

// Wait for the game to fully load before initializing
function rwkInit() {
    // #s_name and the game tables must exist before we init
    if (!document.querySelector('#s_name') || document.querySelectorAll('table').length < 11) {
        setTimeout(rwkInit, 500);
        return;
    }
    rwkMain();
}

setTimeout(rwkInit, 500);
