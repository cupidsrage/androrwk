// ── Captcha Skills — few-shot example store ───────────────────────────────
const captchaSkills = {
    MAX_EXAMPLES: 5,
    STORAGE_KEY: 'rwkCaptchaSkills',

    load() {
        try {
            return JSON.parse(GM_getValue(this.STORAGE_KEY, '[]'));
        } catch(e) { return []; }
    },

    save(examples) {
        try {
            GM_setValue(this.STORAGE_KEY, JSON.stringify(examples));
        } catch(e) {
            captchaLog(`Skills save error: ${e.message}`);
        }
    },

    addExample(base64, answer) {
        let examples = this.load();
        examples.push({ base64, answer, ts: Date.now() });
        if (examples.length > this.MAX_EXAMPLES) {
            examples = examples.slice(-this.MAX_EXAMPLES);
        }
        this.save(examples);
        captchaLog(`Skills updated — ${examples.length}/${this.MAX_EXAMPLES} examples stored`);
    },

    buildFewShotContent() {
        let examples = this.load();
        if (examples.length === 0) return [];
        let blocks = [];
        blocks.push({ type: 'text', text: 'Here are some example captchas with their correct answers:' });
        for (let ex of examples) {
            blocks.push({
                type: 'image',
                source: { type: 'base64', media_type: 'image/png', data: ex.base64 }
            });
            blocks.push({ type: 'text', text: `Correct answer: ${ex.answer}` });
        }
        blocks.push({ type: 'text', text: 'Now solve this new captcha:' });
        return blocks;
    },

    clear() {
        GM_setValue(this.STORAGE_KEY, '[]');
        captchaLog('Skills cleared');
    },

    status() {
        let examples = this.load();
        captchaLog(`Skills: ${examples.length}/${this.MAX_EXAMPLES} examples stored`);
    }
};

function upscaleCaptcha(base64, scale) {
    return new Promise(resolve => {
        const img = new Image();
        img.onload = () => {
            const c = document.createElement('canvas');
            c.width = img.width * scale;
            c.height = img.height * scale;
            const ctx = c.getContext('2d');
            ctx.imageSmoothingEnabled = false; // keep sharp pixels
            ctx.drawImage(img, 0, 0, c.width, c.height);
            captchaLog(`Upscaled ${img.width}x${img.height} → ${c.width}x${c.height}`);
            resolve(c.toDataURL('image/png').split(',')[1]);
        };
        img.src = 'data:image/jpeg;base64,' + base64;
    });
}

function solveCaptcha() {
    if (captchaSolving) { captchaLog('Already solving'); return; }
    if (Date.now() - lastCaptchaSolveTime < 10000) { captchaLog('Cooldown — skipping'); return; }
    const solver = localStorage.captchaSolver || 'gpt';
    const claudeKey = localStorage.captchaApiKey || '';
    const acKey = localStorage.captchaAcKey || '';
    const openaiKey = localStorage.captchaOpenaiKey || '';
    if (solver === 'claude' && !claudeKey) { captchaLog('ERROR: No Claude API key in Settings'); beep(); return; }
    if (solver === 'anticaptcha' && !acKey) { captchaLog('ERROR: No Anti-Captcha key in Settings'); beep(); return; }
    if (solver === 'gpt' && !openaiKey) { captchaLog('ERROR: No OpenAI API key in Settings'); beep(); return; }

    captchaSolving = true;
    captchaLog('Captcha detected — solver=' + solver);

    const captchaImg = document.querySelector('img[src*="/sec/"], img.mycshift');
    if (!captchaImg) { captchaLog('ERROR: No captcha image found'); beep(); captchaSolving = false; return; }

    GM_xmlhttpRequest({
        method: 'GET',
        url: captchaImg.src + '?nc=' + Date.now(),
        responseType: 'arraybuffer',
        onload: function(resp) {
            try {
                if (!resp.response || resp.response.byteLength === 0) { captchaLog('ERROR: Empty image'); beep(); captchaSolving = false; return; }
                let bytes = new Uint8Array(resp.response);
                let binary = '';
                for (let i = 0; i < bytes.byteLength; i++) binary += String.fromCharCode(bytes[i]);
                const base64 = btoa(binary);
                if (solver === 'anticaptcha') {
                    antiCaptchaCreateTask(acKey, base64);
                } else if (solver === 'gpt') {
                    upscaleCaptcha(base64, 3).then(upscaled => {
                        gptSolveCaptcha(openaiKey, upscaled);
                    });
                } else {
                    upscaleCaptcha(base64, 3).then(upscaled => {
                        claudeSolveCaptcha(claudeKey, upscaled);
                    });
                }
            } catch(e) { captchaLog('ERROR: ' + e.message); beep(); captchaSolving = false; }
        },
        onerror: function() { captchaLog('Fetch error'); beep(); captchaSolving = false; }
    });
}


function parseCaptchaAnswer(raw) {
    const exactMatch = raw.match(/^\s*([1-9])\s*$/);
    if (exactMatch) {
        return { answer: parseInt(exactMatch[1], 10), rule: 'exact' };
    }

    const totalMatch = raw.match(/total\s*[:=]?\s*([1-9])/i);
    if (totalMatch) {
        return { answer: parseInt(totalMatch[1], 10), rule: 'total' };
    }

    const standaloneDigits = raw.match(/(?:^|[^\d])([1-9])(?=[^\d]|$)/g);
    if (standaloneDigits && standaloneDigits.length > 0) {
        const lastMatch = standaloneDigits[standaloneDigits.length - 1].match(/([1-9])/);
        return { answer: lastMatch ? parseInt(lastMatch[1], 10) : NaN, rule: 'last-digit' };
    }

    return { answer: NaN, rule: 'none' };
}

