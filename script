function getDirection(unit) {
    let temp;
    unit = parseInt(unit, 10);
    if ([0, 4, 8].includes(unit)) {
        temp = 0;
    }
    if ([1, 5, 9].includes(unit)) {
        temp = 1;
    }
    if ([2, 6, 10].includes(unit)) {
        temp = 2;
    }
    if ([3, 7, 11].includes(unit)) {
        temp = 3;
    }
    return temp;
}

function getFort(unit) {
    let temp;
    unit = parseInt(unit, 10);
    if (unit >= 0 && unit < 4) {
        temp = 0;
    }
    if (unit >= 4 && unit < 8) {
        temp = 1;
    }
    if (unit >= 8 && unit < 12) {
        temp = 2;
    }
    return temp;
}

