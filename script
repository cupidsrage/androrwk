(function() {
    // Hide GM_info global that sites can probe
    try { Object.defineProperty(window, 'GM_info', { get: () => undefined }); } catch(e) {}

    // Hide tampermonkey traces
    try { Object.defineProperty(window, '_tampermonkey', { get: () => undefined }); } catch(e) {}
    try { Object.defineProperty(window, 'tampermonkey', { get: () => undefined }); } catch(e) {}
    try { Object.defineProperty(window, 'TampermonkeyConfig', { get: () => undefined }); } catch(e) {}

    // Block any injected script tags that reference tampermonkey
    const _origAppendChild = Element.prototype.appendChild;
    Element.prototype.appendChild = function(el) {
        if (el && el.src && el.src.indexOf('tampermonkey') > -1) return el;
        return _origAppendChild.call(this, el);
    };

    // Block setAttribute revealing tampermonkey src
    const _origSetAttr = Element.prototype.setAttribute;
    Element.prototype.setAttribute = function(name, value) {
        if (name === 'src' && typeof value === 'string' && value.indexOf('tampermonkey') > -1) return;
        return _origSetAttr.call(this, name, value);
    };
})();
